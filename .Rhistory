padroniza_texto <- function(x) {
x <- as.character(x)
x <- trimws(x)
x <- stri_trans_general(x, "Latin-ASCII")
x <- tolower(x)
x <- gsub("[[:punct:]]", " ", x)
x <- gsub("\\s+", " ", x)
x <- trimws(x)
x
}
