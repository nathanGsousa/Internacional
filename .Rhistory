padroniza_texto <- function(x) {
x <- trimws(x)
x <- iconv(x, from = "UTF-8", to = "ASCII//TRANSLIT")
x <- tolower(x)
x <- gsub("\\s+", " ", x)
x
}
paises[, pais_chave := padroniza_texto(NO_PAIS_POR)]
processa_exportacao_ne <- function(arquivo) {
dt <- read_excel(arquivo)
dt <- as.data.table(dt)
# padronizar nomes das colunas
nomes_novos <- names(dt)
nomes_novos <- str_trim(nomes_novos)
nomes_novos <- str_replace_all(nomes_novos, "\\s+", "_")
nomes_novos <- str_replace_all(nomes_novos, "-", "_")
nomes_novos <- str_replace_all(nomes_novos, "ç", "c")
nomes_novos <- str_replace_all(nomes_novos, "ã", "a")
nomes_novos <- str_replace_all(nomes_novos, "á", "a")
nomes_novos <- str_replace_all(nomes_novos, "é", "e")
nomes_novos <- str_replace_all(nomes_novos, "í", "i")
nomes_novos <- str_replace_all(nomes_novos, "ó", "o")
nomes_novos <- str_replace_all(nomes_novos, "ú", "u")
nomes_novos <- tolower(nomes_novos)
setnames(dt, old = names(dt), new = nomes_novos)
print(names(dt))
# colunas de anos
cols_anos <- grep("^[0-9]{4}", names(dt), value = TRUE)
dt_long <- melt(
dt,
id.vars = c("uf_do_produto", "codigo_sh6", "descricao_sh6", "paises"),
measure.vars = cols_anos,
variable.name = "ano_coluna",
value.name = "valor_fob"
)
dt_long[, ano := as.integer(str_extract(ano_coluna, "[0-9]{4}"))]
dt_long[, `:=`(
uf_produto = uf_do_produto,
hs6 = sprintf("%06d", as.integer(codigo_sh6)),
descricao_hs6 = descricao_sh6,
pais = trimws(paises)
)]
dt_long[, valor_fob := as.numeric(valor_fob)]
dt_long <- dt_long[, .(
uf_produto,
hs6,
descricao_hs6,
pais,
ano,
valor_fob
)]
return(dt_long)
}
