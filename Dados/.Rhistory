library(readr)
library(dplyr)
library(stringr)
# pasta onde estão os arquivos
pasta_baci <- "C:/SEU/CAMINHO/AQUI"
# anos que você quer ler
anos_escolhidos <- 2014:2024
# lista todos os csv da pasta
arquivos <- list.files(
path = pasta_baci,
pattern = "\\.csv$",
full.names = TRUE
)
# manter apenas os arquivos dos anos escolhidos
arquivos_baci <- arquivos[str_detect(arquivos, paste(anos_escolhidos, collapse = "|"))]
# dataframe vazio para ir acumulando
baci_final <- data.frame()
# loop
for (arq in arquivos_baci) {
cat("Lendo:", basename(arq), "\n")
df <- read_csv(arq, show_col_types = FALSE) %>%
select(t, j, k, v) %>%   # só o que importa
mutate(
ano = as.integer(t),
importador = j,
hs6 = as.character(k),
valor = v * 1000,      # transforma de mil USD para USD
periodo = case_when(
ano >= 2014 & ano <= 2019 ~ "P1",
ano >= 2020 & ano <= 2024 ~ "P2",
TRUE ~ NA_character_
)
) %>%
select(ano, periodo, importador, hs6, valor)
baci_final <- bind_rows(baci_final, df)
}
# conferir resultado
glimpse(baci_final)
head(baci_final)
View(baci_final)
View(baci_final)
